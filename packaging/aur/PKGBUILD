# Maintainer: Joonas Tuomi <joonas at cosmic-utils dot org>
# Contributor: cosmic-utils
#
# Stable release package. Each release (vX.Y.Z tag) has its own PKGBUILD
# committed to AUR; CI bumps pkgver + sha256sums and regenerates .SRCINFO
# on tag push (see .github/workflows/publish.yml, job `aur`).
#
# Build dependencies and layout mirror the upstream justfile:
#   - libcosmic is a git dependency (pinned in Cargo.lock), pulled by
#     `cargo fetch --locked` at build time — AUR builders have network.
#   - `package()` runs `just rootdir="$pkgdir" install`, so the on-disk
#     layout stays defined in exactly one place (the justfile).

pkgname=cosmic-utils-enroll
pkgver=1.2.1
pkgrel=1
pkgdesc="GUI for fprintd fingerprint enrolling (COSMIC)"
arch=('x86_64' 'aarch64')
url="https://github.com/cosmic-utils/enroll"
license=('MPL-2.0')
depends=(
  'fprintd'        # the D-Bus daemon the app drives; useless without it
  'gcc-libs'       # libgcc_s.so.1 (ldd)
  'glibc'          # libc.so.6, libm.so.6 (ldd)
  'libxkbcommon'   # libxkbcommon.so.0 (ldd)
)
makedepends=(
  'cargo'            # >= 1.85 for Rust edition 2024
  'fontconfig'       # libcosmic build dep
  'freetype2'        # libcosmic build dep
  'git'              # cargo fetch of the libcosmic git source
  'just'             # install layout (`just rootdir=… install`)
  'pkgconf'          # pkg-config probes during the libcosmic build
  'wayland-protocols'
)
provides=("$pkgname")
conflicts=("$pkgname-git")
source=("$pkgname-$pkgver.tar.gz::$url/archive/refs/tags/v$pkgver.tar.gz")
# sha256sums are regenerated by CI on each tag push.
sha256sums=('SKIP')

# Use $CARCH-appropriate target triple; `cargo fetch --target` speeds the
# build and avoids pulling host-only deps into the target sysroot.
case "$CARCH" in
  x86_64)   _target='x86_64-unknown-linux-gnu' ;;
  aarch64)  _target='aarch64-unknown-linux-gnu' ;;
  *)        _target='unknown' ;;  # let cargo pick
esac

prepare() {
  cd "$pkgname-$pkgver"
  # Cargo.lock ships with the tag; honor it.
  if [ "$_target" != 'unknown' ]; then
    cargo fetch --locked --target "$_target"
  else
    cargo fetch --locked
  fi
}

build() {
  cd "$pkgname-$pkgver"
  # --frozen honors Cargo.lock exactly; --release matches [profile.release]
  # (LTO + strip) upstream already enables.
  cargo build --frozen --release
}

check() {
  cd "$pkgname-$pkgver"
  # Upstream has no test suite; `cargo build --frozen` is the compile gate.
  # Keep the step so a future test harness is wired in automatically.
  :
}

package() {
  cd "$pkgname-$pkgver"
  # Single source of truth for the install layout: the upstream justfile.
  just rootdir="$pkgdir" install

  # LICENSE installs under the SPDX name license helpers expect.
  install -Dm0644 LICENSE \
    "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
